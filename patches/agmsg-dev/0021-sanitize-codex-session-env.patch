+fn is_codex_command(cmd: &str, args: &[String]) -> bool {
+    let name = Path::new(cmd).file_name().and_then(|name| name.to_str());
+    name == Some("codex") || (name == Some("env") && args.iter().any(|arg| arg == "codex"))
+}
