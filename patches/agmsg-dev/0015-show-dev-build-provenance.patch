+fn short_commit(commit: &str) -> &str {
+    let end = commit.len().min(7);
+    &commit[..end]
+}
+
+fn about_version_label() -> String {
+    let app_version = env!("CARGO_PKG_VERSION");
+    if !IS_DEV_BUILD {
+        return app_version.to_string();
+    }
+
+    let base_ref = option_env!("AGMSG_DEV_BASE_REF").unwrap_or("unknown-base");
+    let base_commit = option_env!("AGMSG_DEV_BASE_COMMIT")
+        .map(short_commit)
+        .unwrap_or("unknown");
+    let patch_count = option_env!("AGMSG_DEV_PATCH_COUNT").unwrap_or("unknown");
+    format!("{app_version}-dev (base {base_ref} {base_commit}, patches {patch_count})")
+}
