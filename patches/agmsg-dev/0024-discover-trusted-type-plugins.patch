+/// List spawnable built-in and trusted external agent types. Search order
+/// mirrors agmsg's type registry: built-ins, the default plugins directory,
+/// then AGMSG_PLUGIN_DIRS. Later trusted entries override earlier ones.
+#[tauri::command]
+pub fn agmsg_spawnable_types() -> Result<Vec<AgentType>, String> {
+    let root = agmsg_base();
+    let trusted = trusted_type_plugins(&root);
+    let mut types = BTreeMap::new();
+    collect_spawnable_types(&root.join("scripts/drivers/types"), false, &trusted, &mut types)?;
+    collect_spawnable_types(&root.join("plugins/types"), true, &trusted, &mut types)?;
+    if let Ok(extra) = std::env::var("AGMSG_PLUGIN_DIRS") {
+        for base in extra.split(':').filter(|s| !s.is_empty()) {
+            collect_spawnable_types(&PathBuf::from(base).join("types"), true, &trusted, &mut types)?;
+        }
+    }
+    Ok(types.into_values().collect())
 }

